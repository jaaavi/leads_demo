</div>

<style>
  .phase4-preview-box { padding: 12px; }
  .phase4-preview-text { white-space: pre-wrap; font-size: 0.95rem; margin: 0; }
  .phase4-edit-area { margin-top: 8px; font-family: inherit; }

  .phase-container { transition: all 0.3s ease; }

  @media (max-width: 768px) {
    .modal-xl { max-width: 95vw !important; }
    .phase-container { padding: 1.5rem 1rem !important; margin-bottom: 0.75rem !important; }
    .btn-group { flex-wrap: wrap; }
    .btn-group .btn { min-width: 0; }
    .progress { height: 20px; }
    .table-responsive { font-size: 12px; }
    .table th, .table td { padding: 0.5rem 0.25rem; }
    textarea { font-size: 13px; }
    .alert { padding: 0.75rem; }
  }

  @media (max-width: 576px) {
    .modal-dialog { margin: 0.5rem; }
    .modal-header { padding: 0.75rem; }
    .modal-body { padding: 0.75rem; max-height: 70vh; overflow-y: auto; }
    .modal-footer { padding: 0.75rem; flex-wrap: wrap; }
    .modal-dialog-scrollable { max-height: 95vh; }
    .phase-container { padding: 1rem 0.75rem !important; margin-bottom: 0.5rem !important; }
    h6 { font-size: 0.95rem; }
    .btn { padding: 0.35rem 0.5rem; font-size: 12px; }
    .btn-sm { padding: 0.25rem 0.4rem; font-size: 11px; }
    .form-control, .form-select, textarea { font-size: 13px; padding: 0.35rem 0.5rem; }
    .form-label { font-size: 12px; }
    .progress { height: 18px; }
    .table { font-size: 11px; }
    .table th, .table td { padding: 0.35rem 0.15rem; }
    .alert { padding: 0.5rem; font-size: 12px; }
    .badge { font-size: 10px; padding: 0.3rem 0.5rem; }
    .btn-group-vertical { width: 100%; }
    .btn-group-vertical .btn { width: 100%; text-align: left; }
  }
</style>

<script>
  const funnelModal = new bootstrap.Modal(document.getElementById('funnelModal'));
  let currentFunnelLead = null;
  let currentFunnelStatus = null;
  let editedOpeningText = null;
  let currentStrategy = null;
  let currentStrategyMessages = {};

  // Para comercial_pro, ocultar fase 3 desde el principio (van directo a fase 4)
  document.addEventListener('DOMContentLoaded', () => {
    if (userRole === 'comercial_pro') {
      const phase3Container = document.getElementById('phase3Container');
      if (phase3Container) {
        phase3Container.style.display = 'none !important';
        // Cambiar etiqueta de progreso
        const phaseLabel = document.getElementById('funnelPhaseLabel');
        if (phaseLabel) {
          phaseLabel.textContent = 'Fase 1/3';
        }
      }
    }
  });

  function appendInboundToPhase2(p) {
    try {
      const list = document.getElementById('phase2MessagesList');
      if (!list) return;
      const node = document.createElement('div');
      node.className = 'message-item message-received';
      node.style.padding = '8px';
      node.style.marginBottom = '8px';
      node.style.borderRadius = '6px';
      node.style.background = '#f5f5f5';
      const timestamp = new Date().toLocaleString('es-ES');
      node.innerHTML = `<div style="font-size:12px;color:#666;margin-bottom:6px;">${timestamp}</div><div style="white-space:pre-wrap;color:#333;">${(p.text||p.message||'').replace(/</g,'&lt;')}</div>`;
      // Remove placeholder
      if (list.children.length === 1 && list.children[0].classList.contains('text-muted')) list.innerHTML = '';
      list.insertBefore(node, list.firstChild);
      const parseBtn = document.getElementById('parsePhase2Btn');
      if (parseBtn) parseBtn.disabled = false;
    } catch (e) { console.warn('appendInboundToPhase2 error', e); }
  }

  function appendInboundToPhase1(p) {
    try {
      const list = document.getElementById('phase1ResponsesList');
      if (!list) return;
      const node = document.createElement('div');
      node.className = 'message-item message-received';
      node.style.padding = '8px';
      node.style.marginBottom = '8px';
      node.style.borderRadius = '6px';
      node.style.background = '#f1f8ff';
      const timestamp = new Date().toLocaleString('es-ES');
      node.innerHTML = `<div style="font-size:12px;color:#666;margin-bottom:6px;">${timestamp}</div><div style="white-space:pre-wrap;color:#333;">${(p.text||p.message||'').replace(/</g,'&lt;')}</div>`;
      if (list.children.length === 1 && list.children[0].classList.contains('text-muted')) list.innerHTML = '';
      list.insertBefore(node, list.firstChild);
    } catch (e) { console.warn('appendInboundToPhase1 error', e); }
  }

