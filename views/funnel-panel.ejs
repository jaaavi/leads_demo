<!-- Funnel Panel Modal -->
<div class="modal fade" id="funnelModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header border-bottom">
        <h5 class="modal-title">
          <i class="fa-solid fa-funnel me-2" style="color: #1976d2;"></i>
          <span id="funnelLeadName">Sales Funnel</span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body p-4">
        <!-- Funnel Progress Bar -->
        <div class="mb-4">
          <div class="d-flex justify-content-between mb-2">
            <small class="fw-bold">Progreso del funnel</small>
            <small id="funnelPhaseLabel" class="text-muted">Fase 1/4</small>
          </div>
          <div class="progress" style="height: 24px;">
            <div id="funnelProgressBar" class="progress-bar bg-primary" role="progressbar" style="width: 25%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
        </div>

        <!-- Phase 1: Mensaje de Apertura -->
        <div id="phase1Container" class="phase-container mb-4 p-3 border rounded-2 bg-light">
          <h6 class="mb-3">
            <i class="fa-solid fa-envelope me-2" style="color: #4caf50;"></i>
            Fase 1: Mensaje de Apertura
            <span id="phase1Status" class="badge bg-warning ms-2">Pendiente</span>
            <div class="form-check form-check-inline ms-3">
              <input class="form-check-input" type="checkbox" id="phase1Check">
              <label class="form-check-label" for="phase1Check">Marcado</label>
            </div>
          </h6>
          
          <div class="mb-3">
            <label class="form-label fw-600">Selecciona el tipo de mensaje:</label>
            <div class="btn-group d-grid gap-2" role="group">
              <input type="radio" class="btn-check" name="openingMessageType" id="msgNatural" value="NATURAL">
              <label class="btn btn-outline-primary text-start" for="msgNatural">
                <strong>Opción 1 - Natural</strong><br>
                <small class="text-muted">Agencia pequeña del barrio</small>
              </label>

              <input type="radio" class="btn-check" name="openingMessageType" id="msgCorta" value="CORTA">
              <label class="btn btn-outline-primary text-start" for="msgCorta">
                <strong>Opción 2 - Corta</strong><br>
                <small class="text-muted">Directo y simple</small>
              </label>

              <input type="radio" class="btn-check" name="openingMessageType" id="msgAgencia" value="AGENCIA">
              <label class="btn btn-outline-primary text-start" for="msgAgencia">
                <strong>Opción 3 - Agencia</strong><br>
                <small class="text-muted">Enfoque profesional</small>
              </label>

              <input type="radio" class="btn-check" name="openingMessageType" id="msgPersonal" value="PERSONAL">
              <label class="btn btn-outline-primary text-start" for="msgPersonal">
                <strong>Opción 4 - Personal</strong><br>
                <small class="text-muted">Más cercano y detallado</small>
              </label>
            </div>
          </div>

          <div id="messagePreview" class="alert alert-info d-none">
            <div class="d-flex align-items-start justify-content-between mb-2">
              <small class="fw-bold">Vista previa del mensaje:</small>
              <div>
                <button id="phase1EditBtn" class="btn btn-sm btn-outline-secondary me-1">Editar</button>
                <button id="phase1ResetEditBtn" class="btn btn-sm btn-outline-secondary d-none">Cancelar</button>
              </div>
            </div>
            <p id="messagePreviewText" style="white-space: pre-wrap; margin: 0;"></p>

            <div id="phase1EditArea" class="d-none mt-2">
              <textarea id="phase1EditTextarea" class="form-control" rows="5"></textarea>
              <div class="d-flex gap-2 mt-2">
                <button id="phase1SaveEditBtn" class="btn btn-primary btn-sm">Guardar</button>
                <button id="phase1CancelEditBtn" class="btn btn-outline-secondary btn-sm">Cancelar</button>
              </div>
            </div>
          </div>

          <!-- Phase 1 - Responses panel -->
          <div id="phase1Responses" class="mb-3">
            <small class="fw-bold d-block mb-1">Respuestas al mensaje de apertura:</small>
            <div id="phase1ResponsesList" style="max-height:180px; overflow-y:auto; border:1px solid #eee; padding:8px; border-radius:6px; background:#fff;">
              <div class="text-muted">Aquí aparecerán las respuestas en tiempo real</div>
            </div>
          </div>

          <div class="mb-2 d-flex align-items-center gap-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="sendInPartsCheck">
              <label class="form-check-label" for="sendInPartsCheck">Enviar por partes</label>
            </div>
            <small class="text-muted">Si activas, podrás enviar el mensaje de apertura parte a parte.</small>
          </div>

          <div id="partsContainer" style="display:none; margin-bottom:12px;">
            <small class="fw-bold d-block mb-1">Partes del mensaje:</small>
            <div id="partsList" style="max-height:140px; overflow-y:auto; padding:6px; background:#fff; border:1px solid #dee2e6; border-radius:6px;"></div>
            <div class="d-flex gap-2 mt-2">
              <button id="sendNextPartBtn" class="btn btn-outline-success btn-sm">Enviar siguiente parte</button>
              <button id="sendAllPartsBtn" class="btn btn-success btn-sm">Enviar todo seguido</button>
            </div>
          </div>

          <button id="phase1SendBtn" class="btn btn-success w-100" disabled>
            <i class="fa-solid fa-paper-plane me-2"></i> Enviar Mensaje de Apertura
          </button>
        </div>

        <!-- Phase 2: Recopilación de Información -->
        <div id="phase2Container" class="phase-container mb-4 p-3 border rounded-2 bg-light" style="display:none;">
          <h6 class="mb-3">
            <i class="fa-solid fa-clipboard me-2" style="color: #ff9800;"></i>
            Fase 2: Recopilación de Información
            <span id="phase2Status" class="badge bg-warning ms-2">Pendiente</span>
            <div class="form-check form-check-inline ms-3">
              <input class="form-check-input" type="checkbox" id="phase2Check">
              <label class="form-check-label" for="phase2Check">Marcado</label>
            </div>
          </h6>

          <!-- Incoming replies to opening message -->
          <div id="phase2Messages" class="mb-3">
            <small class="fw-bold d-block mb-1">Respuestas recibidas:</small>
            <div id="phase2MessagesList" style="max-height:200px; overflow-y:auto;">
              <div class="text-muted" style="padding:12px;">Sin respuestas aún</div>
            </div>
          </div>

          <div class="mb-3 d-flex gap-2 align-items-center">
            <button id="sendPhase2CollectBtn" class="btn btn-primary btn-sm"><i class="fa-solid fa-paper-plane me-1"></i> Enviar mensaje de recopilación</button>
            <button id="parsePhase2Btn" class="btn btn-outline-primary btn-sm" disabled>Parsear respuestas</button>
            <button id="phase2PreviewBtn" class="btn btn-outline-secondary btn-sm">Previsualizar / Editar</button>
            <div class="form-check form-check-inline ms-2">
              <input class="form-check-input" type="checkbox" id="phase2SendParts">
              <label class="form-check-label small" for="phase2SendParts">Enviar en partes</label>
            </div>
            <div class="text-muted small ms-auto">Después de parsear, los valores se cargarán en la tabla editable abajo.</div>
          </div>

          <div id="phase2MessagePreviewBox" class="alert alert-info d-none">
            <div class="d-flex align-items-start justify-content-between mb-2">
              <small class="fw-bold">Vista previa del mensaje de recopilación:</small>
              <div>
                <button id="phase2EditBtn" class="btn btn-sm btn-outline-secondary me-1">Editar</button>
                <button id="phase2ResetEditBtn" class="btn btn-sm btn-outline-secondary d-none">Cancelar</button>
              </div>
            </div>
            <p id="phase2MessagePreviewText" class="mb-2" style="white-space:pre-wrap"></p>

            <div id="phase2PartsContainer" class="mt-2" style="display:none;">
              <small class="fw-bold d-block mb-1">Partes a enviar:</small>
              <div id="phase2PartsList" style="max-height:180px; overflow-y:auto; padding:8px; background:#fff; border:1px solid #dee2e6; border-radius:6px;"></div>
              <div class="d-flex gap-2 mt-2">
                <button id="phase2SendNextPartBtn" class="btn btn-outline-success btn-sm">Enviar siguiente parte</button>
                <button id="phase2SendAllPartsBtn" class="btn btn-success btn-sm">Enviar todo seguido</button>
              </div>
            </div>

            <div id="phase2EditArea" class="d-none">
              <textarea id="phase2EditTextarea" class="form-control" rows="5"></textarea>
              <div class="d-flex gap-2 mt-2">
                <button id="phase2SaveEditBtn" class="btn btn-primary btn-sm">Guardar</button>
                <button id="phase2CancelEditBtn" class="btn btn-outline-secondary btn-sm">Cancelar</button>
              </div>
            </div>
          </div>

          <!-- Data table for manual editing / parsed values -->
          <div class="table-responsive mb-3">
            <table class="table table-sm" id="phase2DataTable">
              <tbody>
                <tr><th style="width:260px">Sector / Industria</th><td><input class="form-control" name="sector" /></td></tr>
                <tr><th>Descripción</th><td><input class="form-control" name="descripcion" /></td></tr>
                <tr><th>Servicios / Productos</th><td><textarea class="form-control" name="servicios" rows="2"></textarea></td></tr>
                <tr><th>Estilo web</th><td><input class="form-control" name="estilo_web" /></td></tr>
                <tr><th>Teléfono contacto</th><td><input class="form-control" name="telefofo_contacto" /></td></tr>
                <tr><th>Redes sociales / Web</th><td><input class="form-control" name="redes_sociales" /></td></tr>
                <tr><th>Dirección</th><td><input class="form-control" name="direccion" /></td></tr>
                <tr><th>Referencias visuales</th><td><textarea class="form-control" name="referencias_visuales" rows="2"></textarea></td></tr>
                <tr><th>Fotos representativas</th><td><textarea class="form-control" name="fotos_representativas" rows="2"></textarea></td></tr>
              </tbody>
            </table>
          </div>

          <div class="d-flex gap-2">
            <button id="savePhase2Btn" class="btn btn-warning flex-grow-1"><i class="fa-solid fa-arrow-right me-2"></i> Guardar y Continuar a Fase 3</button>
            <button id="cancelPhase2Btn" class="btn btn-outline-secondary">Cancelar</button>
          </div>
        </div>

        <!-- Phase 3: Generar Prompt con OpenAI -->
        <div id="phase3Container" class="phase-container mb-4 p-3 border rounded-2 bg-light" style="display:none;">
          <h6 class="mb-3">
            <i class="fa-solid fa-brain me-2" style="color: #9c27b0;"></i>
            Fase 3: Generar Prompt para Diseñador
            <span id="phase3Status" class="badge bg-warning ms-2">Pendiente</span>
            <div class="form-check form-check-inline ms-3">
              <input class="form-check-input" type="checkbox" id="phase3Check">
              <label class="form-check-label" for="phase3Check">Marcado</label>
            </div>
          </h6>

          <p class="text-muted small mb-3">Se generará automáticamente un prompt detallado usando OpenAI basado en la información recopilada en Fase 2.</p>

          <div class="mb-3">
            <small class="fw-bold d-block mb-1">Datos parseados (para copiar):</small>
            <div id="phase3DataContainer" class="alert alert-light p-2" style="background:#fff; border:1px solid #dee2e6;">
              <pre id="phase3DataContent" style="margin:0; white-space:pre-wrap; word-wrap:break-word;"></pre>
            </div>
            <div class="d-flex gap-2 mb-3">
              <button id="phase3CopyDataBtn" class="btn btn-sm btn-outline-secondary">
                <i class="fa-solid fa-copy me-1"></i> Copiar datos
              </button>
            </div>
          </div>

          <div class="d-grid gap-2 mb-3">
            <button id="phase3GenerateBtn" class="btn btn-primary w-100">
              <i class="fa-solid fa-sparkles me-2"></i> Generar plantilla (GPT)
            </button>
            <button id="phase3RegenerateBtn" class="btn btn-outline-primary w-100" style="display:none;">
              <i class="fa-solid fa-rotate me-2"></i> Regenerar plantilla
            </button>
          </div>

          <div id="phase3LoadingSpinner" style="display:none;" class="text-center mb-3">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
              <span class="visually-hidden">Generando...</span>
            </div>
            <p class="small text-muted mt-2">Generando plantilla con OpenAI...</p>
          </div>

          <div id="phase3PromptContainer" style="display:none;">
            <div class="alert alert-info">
              <div class="d-flex align-items-start justify-content-between mb-2">
                <small class="fw-bold">Plantilla generada:</small>
                <div>
                  <button id="phase3EditBtn" class="btn btn-sm btn-outline-secondary me-1">Editar</button>
                  <button id="phase3ResetEditBtn" class="btn btn-sm btn-outline-secondary d-none">Cancelar</button>
                </div>
              </div>
              <div id="phase3PromptContent" style="max-height: 400px; overflow-y: auto; white-space: pre-wrap; background: white; padding: 12px; border-radius: 4px; border: 1px solid #dee2e6;"></div>
            </div>

            <div id="phase3EditArea" class="d-none mb-2">
              <textarea id="phase3EditTextarea" class="form-control" rows="6"></textarea>
              <div class="d-flex gap-2 mt-2">
                <button id="phase3SaveEditBtn" class="btn btn-primary btn-sm">Guardar</button>
                <button id="phase3CancelEditBtn" class="btn btn-outline-secondary btn-sm">Cancelar</button>
              </div>
            </div>

            <div class="d-flex gap-2 mb-2 align-items-center">
              <button id="phase3CopyBtn" class="btn btn-sm btn-outline-primary">
                <i class="fa-solid fa-copy me-1"></i> Copiar Plantilla
              </button>
              <button id="phase3SendBtn" class="btn btn-sm btn-danger">Enviar al lead</button>
              <div class="form-check form-check-inline ms-auto">
                <input class="form-check-input" type="checkbox" id="phase3SendParts">
                <label class="form-check-label small" for="phase3SendParts">Enviar en partes</label>
              </div>
            </div>

            <div class="d-flex gap-2">
              <button id="phase3NextBtn" class="btn btn-sm btn-primary flex-grow-1">
                <i class="fa-solid fa-arrow-right me-1"></i> Continuar a Fase 4
              </button>
            </div>
          </div>
        </div>

        <!-- Phase 4: Propuesta y Cierre -->
        <div id="phase4Container" class="phase-container p-3 border rounded-2 bg-light" style="display:none;">
          <h6 class="mb-3">
            <i class="fa-solid fa-gift me-2" style="color: #e91e63;"></i>
            Fase 4: Propuesta y Cierre
            <span id="phase4Status" class="badge bg-warning ms-2">Pendiente</span>
            <div class="form-check form-check-inline ms-3">
              <input class="form-check-input" type="checkbox" id="phase4Check">
              <label class="form-check-label" for="phase4Check">Marcado</label>
            </div>
          </h6>

          <div class="mb-3">
            <label class="form-label fw-600">URL de la previsualización:</label>
            <input type="url" id="phase4PreviewUrl" class="form-control mb-2" placeholder="https://ejemplo.com/preview">
            <button id="phase4UpdateUrlBtn" class="btn btn-sm btn-outline-secondary w-100">
              <i class="fa-solid fa-check me-1"></i> Guardar URL
            </button>
          </div>

          <div class="mb-3">
            <label class="form-label fw-600">Asignar fecha de entrega en calendario:</label>
            <div class="d-flex gap-2">
              <input type="datetime-local" id="phase4AssignDate" class="form-control" />
              <button id="phase4AssignDateBtn" class="btn btn-primary">Asignar</button>
            </div>
            <small class="text-muted d-block mt-2">Si asignas una fecha, aparecerá en tu Calendario y en la lista de leads con esa fecha prevista.</small>
          </div>

          <div class="mb-3">
            <small class="fw-bold d-block mb-1">Selecciona el mensaje a enviar:</small>
            <div id="phase4MessageButtons" class="d-flex flex-wrap gap-2">
              <button class="btn btn-outline-primary btn-sm" data-message-type="ENTREGA_PREVIEW">Entrega Previsualización</button>
              <button class="btn btn-outline-primary btn-sm" data-message-type="PREVISUALIZACION">Previsualización</button>
              <button class="btn btn-outline-primary btn-sm" data-message-type="CLIENTE_BASICO">Cliente Básico</button>
              <button class="btn btn-outline-primary btn-sm" data-message-type="CLIENTE_INTERESADO">Cliente Interesado</button>
              <button class="btn btn-outline-primary btn-sm" data-message-type="CLIENTE_AMBICIOSO">Cliente Ambicioso</button>
            </div>
          </div>

          <div id="phase4MessagePreviewBox" class="alert alert-info d-none phase4-preview-box">
            <div class="d-flex align-items-start justify-content-between mb-2">
              <small class="fw-bold">Vista previa del mensaje:</small>
              <div>
                <button id="phase4EditBtn" class="btn btn-sm btn-outline-secondary me-1">Editar</button>
                <button id="phase4ResetEditBtn" class="btn btn-sm btn-outline-secondary d-none">Cancelar</button>
              </div>
            </div>

            <p id="phase4MessagePreviewText" class="mb-2 phase4-preview-text"></p>

            <div id="phase4EditArea" class="d-none">
              <textarea id="phase4EditTextarea" class="form-control phase4-edit-area" rows="6"></textarea>
              <div class="d-flex gap-2 mt-2">
                <button id="phase4SaveEditBtn" class="btn btn-primary btn-sm">Guardar</button>
                <button id="phase4CancelEditBtn" class="btn btn-outline-secondary btn-sm">Cancelar</button>
              </div>
            </div>

            <div id="phase4PartsContainer" class="mt-3" style="display:none;">
              <small class="fw-bold d-block mb-2">Partes a enviar:</small>
              <div id="phase4PartsList" style="max-height:200px; overflow-y:auto; padding:8px; background:#fff; border:1px solid #dee2e6; border-radius:6px;"></div>
              <div class="d-flex gap-2 mt-2">
                <button id="phase4SendNextPartBtn" class="btn btn-outline-success btn-sm">Enviar siguiente parte</button>
                <button id="phase4SendAllPartsBtn" class="btn btn-success btn-sm">Enviar todo seguido</button>
              </div>
            </div>
          </div>

          <div class="mb-3 d-flex align-items-center gap-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="phase4SendPartsCheck">
              <label class="form-check-label" for="phase4SendPartsCheck">Enviar por partes</label>
            </div>
            <small class="text-muted">Si activas, podrás enviar el mensaje por partes.</small>
          </div>

          <button id="phase4SendBtn" class="btn btn-danger w-100" disabled>
            <i class="fa-solid fa-paper-plane me-2"></i> Enviar Mensaje Seleccionado
          </button>
        </div>
      </div>

      <div class="modal-footer border-top">
        <small class="text-muted me-auto">
          Lead: <strong id="funnelLeadPhone">-</strong> | Email: <strong id="funnelLeadEmail">-</strong>
        </small>
        <div class="btn-group me-2" role="group">
          <button id="funnelPrevBtn" type="button" class="btn btn-outline-secondary">&larr; Anterior</button>
          <button id="funnelNextBtn" type="button" class="btn btn-outline-primary">Siguiente &rarr;</button>
        </div>
        <div class="btn-group me-2" role="group">
          <button id="markDiscardedBtn" type="button" class="btn btn-outline-danger">Descartar</button>
          <button id="markClosedBtn" type="button" class="btn btn-success">Marcar como cerrado</button>
        </div>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
