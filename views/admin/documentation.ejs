<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Documentación - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: #f7f9fc;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .admin-docs-container {
      display: flex;
      min-height: 100vh;
    }

    .admin-docs-sidebar {
      width: 280px;
      background: #f6f8fa;
      border-right: 1px solid #e1e4e8;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      padding: 24px 16px;
    }

    .admin-docs-content {
      flex: 1;
      max-width: 1200px;
      padding: 48px 32px;
      overflow-y: auto;
    }

    .admin-docs-sidebar h5 {
      font-size: 12px;
      font-weight: 600;
      color: #586069;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 16px;
      margin-top: 24px;
      padding: 0 8px;
    }

    .admin-docs-sidebar h5:first-child {
      margin-top: 0;
    }

    .admin-docs-sidebar a {
      display: block;
      padding: 8px 12px;
      margin-bottom: 4px;
      color: #586069;
      text-decoration: none;
      border-radius: 6px;
      font-size: 13px;
      transition: all 0.2s;
      border-left: 3px solid transparent;
      cursor: pointer;
    }

    .admin-docs-sidebar a:hover {
      background: #e1e4e8;
      color: #24292e;
      border-left-color: #0366d6;
    }

    .admin-docs-sidebar a.active {
      background: #e1e4e8;
      color: #0366d6;
      font-weight: 600;
      border-left-color: #0366d6;
    }

    .admin-docs-header {
      margin-bottom: 40px;
      border-bottom: 2px solid #e1e4e8;
      padding-bottom: 32px;
    }

    .admin-docs-header h1 {
      font-size: 48px;
      font-weight: 700;
      color: #24292e;
      margin: 0 0 16px;
      letter-spacing: -1px;
    }

    .admin-docs-header p {
      font-size: 18px;
      color: #586069;
      margin: 0;
    }

    .admin-docs-content h2 {
      font-size: 32px;
      font-weight: 700;
      color: #24292e;
      margin: 48px 0 24px;
      padding-top: 24px;
      border-top: 1px solid #e1e4e8;
    }

    .admin-docs-content h2:first-of-type {
      border-top: none;
      padding-top: 0;
      margin-top: 0;
    }

    .admin-docs-content h3 {
      font-size: 20px;
      font-weight: 600;
      color: #24292e;
      margin: 32px 0 16px;
    }

    .admin-docs-content h4 {
      font-size: 16px;
      font-weight: 600;
      color: #24292e;
      margin: 24px 0 12px;
    }

    .admin-docs-content p {
      font-size: 15px;
      color: #24292e;
      line-height: 1.6;
      margin: 0 0 16px;
    }

    .admin-docs-content ul, .admin-docs-content ol {
      font-size: 15px;
      color: #24292e;
      line-height: 1.8;
      margin: 16px 0 16px 24px;
      padding: 0;
    }

    .admin-docs-content li {
      margin-bottom: 8px;
    }

    .role-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .role-badge-admin {
      background: #0366d6;
      color: white;
    }

    .role-badge-comercial {
      background: #28a745;
      color: white;
    }

    .role-badge-comercial-pro {
      background: #6f42c1;
      color: white;
    }

    .doc-section {
      display: none;
    }

    .doc-section.active {
      display: block;
    }

    .code-block {
      background: #f6f8fa;
      border: 1px solid #e1e4e8;
      border-radius: 6px;
      padding: 16px;
      margin: 16px 0;
      font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
      font-size: 13px;
      overflow-x: auto;
    }

    .highlight {
      background: #fff3cd;
      padding: 2px 6px;
      border-radius: 3px;
      font-weight: 500;
    }

    @media (max-width: 768px) {
      .admin-docs-container {
        flex-direction: column;
      }

      .admin-docs-sidebar {
        width: 100%;
        height: auto;
        position: static;
        border-right: none;
        border-bottom: 1px solid #e1e4e8;
        padding: 16px;
      }

      .admin-docs-content {
        padding: 24px 16px;
      }

      .admin-docs-header h1 {
        font-size: 28px;
      }

      .admin-docs-content h2 {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
<%- include('../navbar') %>

<div class="admin-docs-container">
  <div class="admin-docs-sidebar">
    <div style="margin-bottom: 24px;">
      <a href="/admin/users" style="padding: 0; border: none; color: #0366d6; font-weight: 600; margin-bottom: 16px;">
        <i class="fa-solid fa-arrow-left"></i> Volver a Admin
      </a>
    </div>

    <h5>Documentación</h5>
    <a onclick="switchSection('admin')" class="active" data-section="admin">
      <i class="fa-solid fa-user-tie"></i> Administrador
    </a>
    <a onclick="switchSection('comercial')" data-section="comercial">
      <i class="fa-solid fa-user"></i> Comercial
    </a>
    <a onclick="switchSection('comercial-pro')" data-section="comercial-pro">
      <i class="fa-solid fa-user-check"></i> Comercial Pro
    </a>
  </div>

  <div class="admin-docs-content">
    <!-- ADMIN DOCUMENTATION -->
    <div id="admin-section" class="doc-section active">
      <div class="admin-docs-header">
        <span class="role-badge role-badge-admin"><i class="fa-solid fa-user-tie"></i> Administrador</span>
        <h1>Documentación para Administradores</h1>
        <p>Guía completa para gestionar el sistema de leads y lugares</p>
      </div>

      <h2>Gestión de Usuarios</h2>
      <h3>Crear un nuevo usuario</h3>
      <p>Para crear un nuevo usuario:</p>
      <ol>
        <li>Ve a <span class="highlight">Admin > Usuarios</span></li>
        <li>Haz clic en el botón <span class="highlight">+ Nuevo usuario</span></li>
        <li>Ingresa los datos del usuario (nombre, email, rol)</li>
        <li>Asigna el rol apropiado: Admin, Comercial o Comercial Pro</li>
        <li>Haz clic en <span class="highlight">Guardar</span></li>
      </ol>

      <h3>Cambiar rol de usuario</h3>
      <p>Para cambiar el rol de un usuario existente:</p>
      <ol>
        <li>Ve a <span class="highlight">Admin > Usuarios</span></li>
        <li>Encuentra el usuario en la lista</li>
        <li>Haz clic en el botón de editar rol</li>
        <li>Selecciona el nuevo rol</li>
        <li>Haz clic en <span class="highlight">Guardar</span></li>
      </ol>

      <h2>Gestión de Leads</h2>
      <h3>Ver todos los leads</h3>
      <p>Ve a <span class="highlight">Leads</span> para ver la tabla completa de leads. Tienes acceso a todos los leads del sistema.</p>

      <h3>Filtrar leads</h3>
      <p>Puedes filtrar los leads por:</p>
      <ul>
        <li>Nombre o email (búsqueda por texto)</li>
        <li>Estado (Nuevo, Contactado, Interesado, etc.)</li>
        <li>Fase del funnel (Fase 1, 2, 3, 4)</li>
        <li>Ciudad</li>
        <li>Tipo de teléfono (Móvil, Fijo)</li>
        <li>Fuente</li>
        <li>Si tiene web o no</li>
        <li>Asignado a un usuario específico</li>
        <li>Pendiente de contestar</li>
      </ul>

      <h3>Acciones masivas en leads</h3>
      <p>Selecciona múltiples leads y realiza acciones en lote:</p>
      <ul>
        <li><span class="highlight">Asignar</span> - Asigna los leads seleccionados a un usuario</li>
        <li><span class="highlight">Eliminar</span> - Elimina los leads seleccionados</li>
      </ul>

      <h3>Paginación configurable</h3>
      <p>Selecciona cuántos leads deseas ver por página: 10, 20, 50 o 100 items.</p>

      <h2>Gestión de Places</h2>
      <h3>Ver todos los lugares</h3>
      <p>Ve a <span class="highlight">Places</span> para ver la tabla completa de lugares encontrados por el scraper.</p>

      <h3>Acciones masivas en places</h3>
      <p>Selecciona múltiples places y realiza acciones en lote:</p>
      <ul>
        <li><span class="highlight">Convertir en leads</span> - Convierte los lugares seleccionados en leads</li>
        <li><span class="highlight">Eliminar</span> - Elimina los lugares seleccionados</li>
      </ul>

      <h3>Paginación configurable</h3>
      <p>Selecciona cuántos lugares deseas ver por página: 10, 20, 50 o 100 items.</p>

      <h2>Búsquedas y Scraper (GAPI)</h2>
      <h3>Ejecutar una búsqueda manual</h3>
      <ol>
        <li>Ve a la pantalla principal (Dashboard)</li>
        <li>En la sección <span class="highlight">Ejecutar búsqueda (GAPI)</span>, ingresa:</li>
        <ul style="margin-top: 8px;">
          <li>Consulta: "restaurantes madrid"</li>
          <li>Latitud y Longitud (opcional)</li>
          <li>Radio en metros (opcional)</li>
        </ul>
        <li>Haz clic en <span class="highlight">Buscar y guardar</span></li>
      </ol>

      <h3>Ejecutar variaciones automáticas</h3>
      <p>Las variaciones buscan automáticamente con diferentes términos para encontrar más resultados:</p>
      <ol>
        <li>Ve a la sección <span class="highlight">Variaciones</span></li>
        <li>Ingresa un lugar (ej: "Madrid")</li>
        <li>Haz clic en <span class="highlight">Ejecutar</span></li>
        <li>El sistema hará 12 búsquedas diferentes automáticamente</li>
      </ol>

      <h3>Monitorear jobs</h3>
      <p>En la tabla <span class="highlight">Jobs (cola y ejecuciones)</span> puedes ver:</p>
      <ul>
        <li>Estado de cada búsqueda (Pendiente, Ejecutando, Finalizado)</li>
        <li>Cantidad de resultados procesados</li>
        <li>Total de variaciones</li>
      </ul>
      <p>En la tabla <span class="highlight">Jobs Finalizados</span> ves un histórico de todas las búsquedas completadas.</p>

      <h2>WhatsApp</h2>
      <h3>Configuración</h3>
      <p>Ve a <span class="highlight">WhatsApp</span> para:</p>
      <ul>
        <li>Escanear código QR para conectar tu instancia</li>
        <li>Gestionar plantillas de mensajes</li>
        <li>Ver estado de la conexión</li>
      </ul>

      <h3>Enviar mensajes</h3>
      <p>Desde la pantalla de Leads, puedes enviar mensajes por WhatsApp personalizados a cada lead usando variables como {nombre}, {phone}, {email}.</p>
    </div>

    <!-- COMERCIAL DOCUMENTATION -->
    <div id="comercial-section" class="doc-section">
      <div class="admin-docs-header">
        <span class="role-badge role-badge-comercial"><i class="fa-solid fa-user"></i> Comercial</span>
        <h1>Documentación para Usuarios Comerciales</h1>
        <p>Guía para gestionar leads y hacer seguimiento de clientes</p>
      </div>

      <h2>Acceso permitido</h2>
      <p>Como usuario Comercial, tienes acceso a:</p>
      <ul>
        <li><span class="highlight">Leads</span> - Tu cartera de clientes para hacer seguimiento</li>
        <li><span class="highlight">Calendar</span> - Calendario de entregas programadas</li>
        <li><span class="highlight">Manual</span> - Esta documentación</li>
      </ul>

      <h2>Gestión de Leads</h2>
      <h3>Ver tus leads</h3>
      <p>Ve a <span class="highlight">Leads</span> para ver los leads que te han sido asignados.</p>

      <h3>Filtrar leads</h3>
      <p>Puedes filtrar tus leads por:</p>
      <ul>
        <li>Nombre o email</li>
        <li>Estado del lead</li>
        <li>Ciudad</li>
        <li>Fuente</li>
        <li>Otros criterios</li>
      </ul>

      <h3>Editar un lead</h3>
      <ol>
        <li>Haz clic en el botón <i class="fa-solid fa-pen"></i> para editar el lead</li>
        <li>Actualiza la información en la pestaña <span class="highlight">Datos generales</span></li>
        <li>Añade notas en la pestaña <span class="highlight">Notas</span></li>
        <li>Haz clic en <span class="highlight">Guardar</span></li>
      </ol>

      <h3>Ver historial de cambios</h3>
      <p>Haz clic en el botón <i class="fa-solid fa-clock"></i> para ver el historial completo de cambios y acciones en ese lead.</p>

      <h3>Paginación configurable</h3>
      <p>Selecciona cuántos leads deseas ver por página: 10, 20, 50 o 100 items.</p>

      <h2>Guiones de Llamada</h2>
      <h3>Primera contactación</h3>
      <p>Cuando contactes por primera vez con un lead:</p>
      <ol>
        <li>Preséntate y menciona cómo obtuviste su contacto</li>
        <li>Explica brevemente qué ofreces</li>
        <li>Pregunta si es buen momento para hablar</li>
        <li>Anota el resultado en el lead (Contactado, Interesado, etc.)</li>
      </ol>

      <h3>Seguimiento</h3>
      <p>Para leads que mostraron interés:</p>
      <ol>
        <li>Haz seguimiento regularmente</li>
        <li>Actualiza el estado en la plataforma</li>
        <li>Añade notas sobre el progreso de la negociación</li>
        <li>Marca los leads cerrados cuando finalices la venta</li>
      </ol>

      <h2>Calendario de Entregas</h2>
      <h3>Ver entregas programadas</h3>
      <p>Ve a <span class="highlight">Calendar</span> para ver los leads que tienen entregas/previsualizaciones programadas.</p>

      <h3>Actualizar fecha de entrega</h3>
      <ol>
        <li>Desde el calendario, selecciona un lead</li>
        <li>Actualiza la fecha de entrega si es necesario</li>
        <li>Los cambios se guardan automáticamente</li>
      </ol>

      <h2>Notas importantes</h2>
      <ul>
        <li>No puedes crear leads nuevos directamente desde esta pantalla</li>
        <li>No puedes acceder a lugares (Places) - eso es responsabilidad del administrador</li>
        <li>Enfócate en el seguimiento y cierre de los leads asignados</li>
      </ul>
    </div>

    <!-- COMERCIAL PRO DOCUMENTATION -->
    <div id="comercial-pro-section" class="doc-section">
      <div class="admin-docs-header">
        <span class="role-badge role-badge-comercial-pro"><i class="fa-solid fa-user-check"></i> Comercial Pro</span>
        <h1>Documentación para Usuarios Comerciales Pro</h1>
        <p>Guía para generar leads automáticamente y gestionar tu cartera</p>
      </div>

      <h2>Acceso permitido</h2>
      <p>Como usuario Comercial Pro, tienes acceso a:</p>
      <ul>
        <li><span class="highlight">Generador de Lugares</span> - Busca automáticamente lugares en Google Maps</li>
        <li><span class="highlight">Places</span> - Gestiona los lugares que encontraste</li>
        <li><span class="highlight">Leads</span> - Tus leads generados</li>
        <li><span class="highlight">Calendar</span> - Calendario de entregas programadas</li>
        <li><span class="highlight">Manual</span> - Esta documentación</li>
      </ul>

      <h2>Generador de Lugares (Variaciones Automáticas)</h2>
      <h3>¿Cómo funciona?</h3>
      <p>El generador de lugares busca automáticamente en Google Maps usando 12 variaciones diferentes de tu búsqueda. Por ejemplo, si buscas "Madrid", hará búsquedas como:</p>
      <ul>
        <li>Negocios cerca de Madrid</li>
        <li>Restaurantes cerca de Madrid</li>
        <li>Tiendas cerca de Madrid</li>
        <li>Y 9 búsquedas más...</li>
      </ul>

      <h3>Generar lugares</h3>
      <ol>
        <li>En la sección <span class="highlight">Generador de Lugares</span>, ingresa el nombre de un lugar (ciudad, barrio, zona)</li>
        <li>Haz clic en <span class="highlight">Generar Lugares</span></li>
        <li>El sistema mostrará las 12 búsquedas que hará</li>
        <li>Haz clic en <span class="highlight">Confirmar y ejecutar</span></li>
        <li>Verás una barra de progreso mostrando qué búsquedas se han completado (0/12)</li>
        <li>Cuando termine, los lugares aparecerán automáticamente en tu sección de Places</li>
      </ol>

      <h3>Mis búsquedas completadas</h3>
      <p>Una vez que completes una búsqueda, aparecerá en la tabla <span class="highlight">Mis búsquedas completadas</span> con:</p>
      <ul>
        <li>ID de la búsqueda</li>
        <li>Nombre del lugar</li>
        <li>Total de variaciones procesadas</li>
        <li>Fecha de finalización</li>
      </ul>

      <h2>Gestión de Places (Lugares)</h2>
      <h3>Ver mis lugares</h3>
      <p>Ve a <span class="highlight">Places</span> para ver todos los lugares que has generado.</p>

      <h3>Filtrar lugares</h3>
      <p>Puedes filtrar por:</p>
      <ul>
        <li>Nombre de lugar</li>
        <li>Categoría</li>
        <li>Teléfono (Móvil/Fijo)</li>
        <li>Si tiene web</li>
      </ul>

      <h3>Editar un lugar</h3>
      <p>Haz clic en el botón <i class="fa-solid fa-pen"></i> para editar información del lugar (tags, notas, etc.)</p>

      <h3>Convertir lugar a lead</h3>
      <p>Para convertir un lugar en un lead (cliente potencial):</p>
      <ol>
        <li>Haz clic en el botón <i class="fa-solid fa-user-plus"></i> "Crear lead"</li>
        <li>El lugar se convertirá automáticamente en un lead en tu cartera</li>
        <li>Aparecerá en la sección de Leads listo para hacer seguimiento</li>
      </ol>

      <h3>Acciones masivas</h3>
      <p>Selecciona múltiples places y:</p>
      <ul>
        <li><span class="highlight">Convertir en leads</span> - Convierte todos los seleccionados a leads de una vez</li>
        <li><span class="highlight">Eliminar</span> - Elimina los lugares que no te interesen</li>
      </ul>

      <h3>Paginación configurable</h3>
      <p>Selecciona cuántos lugares deseas ver por página: 10, 20, 50 o 100 items.</p>

      <h2>Gestión de Leads</h2>
      <h3>Ver tus leads</h3>
      <p>Ve a <span class="highlight">Leads</span> para ver los leads que has generado o que te han sido asignados.</p>

      <h3>Editar un lead</h3>
      <ol>
        <li>Haz clic en el botón <i class="fa-solid fa-pen"></i></li>
        <li>Actualiza nombre, email, teléfono, estado, etc.</li>
        <li>Usa la pestaña <span class="highlight">Notas</span> para registrar progreso</li>
        <li>Haz clic en <span class="highlight">Guardar</span></li>
      </ol>

      <h3>Estados de lead</h3>
      <p>Los estados principales son:</p>
      <ul>
        <li><span class="highlight">Nuevo</span> - Recién creado, aún no contactado</li>
        <li><span class="highlight">Contactado</span> - Hiciste primer contacto</li>
        <li><span class="highlight">Interesado</span> - Mostró interés en tu oferta</li>
        <li><span class="highlight">En negociación</span> - Estás negociando detalles</li>
        <li><span class="highlight">Cerrado</span> - Completaste la venta</li>
        <li><span class="highlight">Descartado</span> - No es un cliente potencial</li>
      </ul>

      <h3>Paginación configurable</h3>
      <p>Selecciona cuántos leads deseas ver por página: 10, 20, 50 o 100 items.</p>

      <h2>Calendario de Entregas</h2>
      <h3>Usar el calendario</h3>
      <p>Ve a <span class="highlight">Calendar</span> para ver y programar fechas de entrega o previsualizaciones.</p>

      <h2>Consejos prácticos</h2>
      <ul>
        <li>Empieza con búsquedas específicas por zona o ciudad</li>
        <li>Convierte los mejores lugares en leads rápidamente</li>
        <li>Mantén notas detalladas del progreso de cada lead</li>
        <li>Usa el filtro de lugares para enfocarte en categorías específicas</li>
        <li>Haz seguimiento regular a los leads en progreso</li>
      </ul>
    </div>
  </div>
</div>

<script>
  function switchSection(section) {
    // Hide all sections
    document.querySelectorAll('.doc-section').forEach(el => {
      el.classList.remove('active');
    });
    
    // Remove active class from all links
    document.querySelectorAll('.admin-docs-sidebar a').forEach(el => {
      el.classList.remove('active');
    });
    
    // Show selected section
    const sectionEl = document.getElementById(section + '-section');
    if (sectionEl) {
      sectionEl.classList.add('active');
    }
    
    // Mark link as active
    const link = document.querySelector(`.admin-docs-sidebar a[data-section="${section}"]`);
    if (link) {
      link.classList.add('active');
    }
    
    // Scroll to top
    document.querySelector('.admin-docs-content').scrollTop = 0;
  }
</script>
</body>
</html>
