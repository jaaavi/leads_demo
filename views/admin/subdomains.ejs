<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Subdominios - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <style>
    body { background: #f7f9fc; }
    .page { max-width: 1100px; margin: 28px auto; padding: 0 15px; }
    .card-shadow { box-shadow: 0 6px 18px rgba(13,38,76,0.06); }
    .table-wrapper { overflow-x: auto; }
    @media (max-width: 768px) { .page { padding: 0 10px; margin: 15px auto; } }
  </style>
</head>
<body>
  <%- include('../navbar') %>
  <div class="page container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4 mb-0"><i class="fa-solid fa-earth-europe me-2"></i>Subdominios (<%= domain %>)</h1>
      <button id="refreshBtn" class="btn btn-outline-secondary"><i class="fa-solid fa-arrows-rotate"></i></button>
    </div>

    <div class="card card-shadow mb-4">
      <div class="card-body">
        <h5 class="card-title">Crear subdominio (A -> 192.0.2.10, DNS only)</h5>
        <div class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label small">Subdominio</label>
            <div class="input-group">
              <span class="input-group-text">https://</span>
              <input id="subdomainInput" class="form-control" placeholder="miweb" />
              <span class="input-group-text">.<%= domain %></span>
            </div>
          </div>
          <div class="col-md-3">
            <label class="form-label small">Destino</label>
            <input class="form-control" value="192.0.2.10" disabled />
          </div>
          <div class="col-md-2">
            <label class="form-label small">Tipo</label>
            <input class="form-control" value="A (DNS only)" disabled />
          </div>
          <div class="col-md-2">
            <button id="createBtn" class="btn btn-primary w-100"><i class="fa-solid fa-plus me-1"></i>Crear</button>
          </div>
        </div>
        <div id="resultBox" class="mt-3"></div>
      </div>
    </div>

    <div class="card card-shadow">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h5 class="card-title mb-0">Registros A</h5>
          <div class="d-flex gap-2">
            <input id="searchInput" class="form-control" placeholder="Buscar subdominio" style="max-width: 240px;" />
            <button id="searchBtn" class="btn btn-outline-primary">Buscar</button>
          </div>
        </div>
        <div class="table-wrapper">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Nombre</th>
                <th>Contenido</th>
                <th>TTL</th>
                <th>Proxied</th>
              </tr>
            </thead>
            <tbody id="recordsBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    const base = '';
    const apiJson = async (p, opt = {}) => fetch(p, Object.assign({ headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' } }, opt)).then(r=>r.json());

    function renderRecords(records){
      const tbody = document.getElementById('recordsBody');
      if (!records || records.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-muted text-center py-3">Sin registros</td></tr>';
        return;
      }
      tbody.innerHTML = records.map(r => `
        <tr>
          <td><strong>${r.name}</strong></td>
          <td>${r.content || '-'}</td>
          <td>${r.ttl === 1 ? 'auto' : r.ttl}</td>
          <td>${r.proxied ? 'Sí' : 'No'}</td>
        </tr>
      `).join('');
    }

    async function loadRecords(){
      const q = document.getElementById('searchInput').value.trim();
      const url = q ? `${base}/api/admin/subdomains?q=${encodeURIComponent(q)}` : `${base}/api/admin/subdomains`;
      try{
        const res = await apiJson(url);
        if (res.ok) renderRecords(res.records);
      }catch(e){ console.warn(e); }
    }

    document.getElementById('refreshBtn').onclick = loadRecords;
    document.getElementById('searchBtn').onclick = loadRecords;

    document.getElementById('createBtn').onclick = async () => {
      const sub = document.getElementById('subdomainInput').value.trim();
      const box = document.getElementById('resultBox');
      if (!sub) { box.innerHTML = '<div class="alert alert-warning">Introduce un subdominio</div>'; return; }
      try{
        document.getElementById('createBtn').disabled = true;
        document.getElementById('createBtn').innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> Creando...';
        const res = await apiJson(`${base}/api/admin/subdomains`, { method: 'POST', body: JSON.stringify({ subdomain: sub }) });
        if (res.ok) {
          box.innerHTML = `<div class="alert alert-success"><i class="fa-solid fa-check-circle me-1"></i>Creado: <strong>${res.record?.name || ''}</strong></div>`;
          loadRecords();
        } else {
          box.innerHTML = `<div class="alert alert-danger">${res.error || 'Error'}</div>`;
        }
      } catch(e){
        box.innerHTML = `<div class="alert alert-danger">${e.message}</div>`;
      } finally {
        document.getElementById('createBtn').disabled = false;
        document.getElementById('createBtn').innerHTML = '<i class="fa-solid fa-plus me-1"></i>Crear';
      }
    };

    loadRecords();
  </script>
</body>
</html>
