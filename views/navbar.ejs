<script>
  (() => {
    const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
    const links = Array.from(document.querySelectorAll('.app-navbar .nav-link[href]'));
    let activeLink = links.find((link) => {
      const href = link.getAttribute('href');
      return href !== '/' && currentPath.startsWith(href);
    });

    if (!activeLink) {
      activeLink = links.find((link) => link.getAttribute('href') === currentPath);
    }

    if (activeLink) {
      activeLink.classList.add('active');
      activeLink.setAttribute('aria-current', 'page');
    }

    const collapseEl = document.getElementById('navbarNav');
    links.forEach((link) => {
      link.addEventListener('click', () => {
        if (window.innerWidth >= 1200 || !collapseEl?.classList.contains('show') || !window.bootstrap) return;
        window.bootstrap.Collapse.getOrCreateInstance(collapseEl).hide();
      });
    });
  })();
</script>
